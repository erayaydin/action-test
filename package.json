{
  "name": "openapi-sync-action",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "typecheck": "tsc --noEmit",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "prettier": "@fingerprintjs/prettier-config-dx-team",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "minimatch": "^9.0.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "esbuild@<=0.24.2": "^0.25.0"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@fingerprintjs/changesets-changelog-format": "^0.2.0",
    "@fingerprintjs/eslint-config-dx-team": "^0.2.0",
    "@fingerprintjs/prettier-config-dx-team": "^0.3.0",
    "@fingerprintjs/tsconfig-dx-team": "^0.0.2",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^8.56.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
